# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# .zshrc - Simplified Zsh configuration

# Set environment variables
export DOTFILES="$HOME/.dotfiles/lib"
export PYENV_ROOT="$HOME/.pyenv"
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PYENV_ROOT/bin:$PNPM_HOME:/opt/homebrew/opt/openssl@1.1/bin:/opt/homebrew/opt/flex/bin:/opt/homebrew/opt/bison/bin:/opt/homebrew/opt/libpcap/bin:$PATH"

# Load dotfiles (if directory exists)
if [[ -d "$DOTFILES" ]]; then
  for loader in "$DOTFILES"/*.sh; do
    source "$loader"
  done
fi

# Zsh configuration settings
typeset -aU path
autoload -Uz compinit && compinit     # Initialize completion system
autoload -Uz colors && colors         # Enable color support
unsetopt correct_all                  # Disable autocorrect to avoid delays

# Initialize pyenv
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

# Load Powerlevel10k theme
if [[ -f /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme ]]; then
  source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
fi
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# Fuzzy finder - fzf
if command -v fzf >/dev/null 2>&1; then
  source "$(brew --prefix)/opt/fzf/shell/completion.zsh"
  source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
fi

# Load custom completions
[[ -f ~/.zsh_completions ]] && source ~/.zsh_completions

# Homebrew command-not-found handler
HB_CNF_HANDLER="$(brew --prefix)/Homebrew/Library/Taps/homebrew/homebrew-command-not-found/handler.sh"
[[ -f "$HB_CNF_HANDLER" ]] && source "$HB_CNF_HANDLER"

# Aliases
alias zshconfig="nano ~/.zshrc"
alias ohmyzsh="nano ~/.oh-my-zsh"

# Enable 'thefuck' to trigger on pressing Esc twice
autoload -U expand-or-complete
zle -N trigger_thefuck
bindkey -M emacs '\e\e' trigger_thefuck
bindkey -M viins '\e\e' trigger_thefuck
trigger_thefuck() {
  BUFFER="fuck"
  zle accept-line
}

# Load PNPM (for Zsh only)
if [[ "$SHELL" == "/bin/zsh" ]]; then
  export PATH="$PNPM_HOME:$PATH"
fi

# Display system info using fastfetch
if command -v fastfetch >/dev/null 2>&1; then
  fastfetch
fi
